<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#0E5C55">
  <link rel="manifest" href="/manifest.json">
  <title>Ingresar · <%= APP_NAME %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="login-wrap">
  <div class="login-card">
    <div class="login-brand">
      <div class="logo">A</div>
      <div class="name"><span class="ax">AxSoft</span> <span class="contable">Contable</span></div>
      <div class="tag">Gestión de tu negocio, desde el celular</div>
    </div>
    <% if (error) { %><div class="alert"><%= error %></div><% } %>
    <form method="post" action="/login">
      <label for="usuario">Usuario</label>
      <input type="text" id="usuario" name="usuario" autocomplete="username" autocapitalize="none" required>
      <label for="password">Contraseña</label>
      <input type="password" id="password" name="password" autocomplete="current-password" required>
      <button class="primary" type="submit">Ingresar</button>
    </form>
  </div>
</div>
</body>
</html>
