<%
  var _secciones = [
    { key: 'ventas',    href: '/ventas',    label: 'Ventas',
      ico: '<svg viewBox="0 0 24 24"><path d="M6 3h12v17l-2.5-1.6L13 20l-2.5-1.6L8 20l-2-1.6V3z"/><path d="M9 8h6M9 12h4"/></svg>' },
    { key: 'stock',     href: '/stock',     label: 'Stock',
      ico: '<svg viewBox="0 0 24 24"><path d="M3 7.5L12 3l9 4.5-9 4.5-9-4.5z"/><path d="M3 7.5v9L12 21l9-4.5v-9"/><path d="M12 12v9"/></svg>' },
    { key: 'gastos',    href: '/gastos',    label: 'Gastos',
      ico: '<svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="13" rx="2.2"/><path d="M3 10.2h18"/><circle cx="17" cy="14.3" r="1.3"/></svg>' },
    { key: 'pedidos',   href: '/pedidos',   label: 'Pedidos',
      ico: '<svg viewBox="0 0 24 24"><circle cx="6.2" cy="6.5" r="2.3"/><circle cx="6.2" cy="17.5" r="2.3"/><path d="M20 5L8.6 14.3M8.6 9.7L20 19"/></svg>' },
    { key: 'contactos', href: '/contactos', label: 'Agenda',
      ico: '<svg viewBox="0 0 24 24"><rect x="4.5" y="3" width="15" height="18" rx="2"/><path d="M8.5 3v18"/><circle cx="14.5" cy="10" r="2"/><path d="M11.3 16.3c0-1.8 1.4-3.1 3.2-3.1s3.2 1.3 3.2 3.1"/></svg>' }
  ];
  var _puede = function(key){
    if (!user) return false;
    if (user.rol === 'dueno' || user.rol === 'superadmin') return true;
    return (user.permisos || []).indexOf(key) !== -1;
  };
%>
</main>
<nav class="bottom">
<div class="side-brand"><span class="side-brand-logo">Ax</span><span>AxSoft <b>Contable</b></span></div>
<% _secciones.forEach(function(s){ if (_puede(s.key)) { %>
  <a href="<%= s.href %>" class="<%= activeNav===s.key ? 'active':'' %>"><span class="ico"><%- s.ico %></span><%= s.label %></a>
<% } }); %>
</nav>
