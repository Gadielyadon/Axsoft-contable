<%- include('partials/head') %>
<% var micSvg = '<svg viewBox="0 0 24 24"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0014 0"/><path d="M12 18v4M8 22h8"/></svg>'; %>
<h1 class="title">Registrar venta</h1>

<div class="layout-2col">
<div class="col-form">
<div class="card">
  <form method="post" action="/ventas" id="form-venta">
    <label for="v-vendedor">Vendedor/a</label>
    <select id="v-vendedor" name="vendedor">
      <% empleados.forEach(function(e){ %><option><%= e.nombre %></option><% }); %>
      <option>Otra</option>
    </select>

    <% if (stock.length) { %>
    <label for="v-buscar">Buscar producto</label>
    <div class="buscador">
      <div class="field-mic">
        <input type="text" id="v-buscar" autocomplete="off" placeholder="Escribí y tocá el producto..."
               oninput="buscarStock(this.value)" onfocus="buscarStock(this.value)">
        <button type="button" class="mic" onclick="dictar('v-buscar', this)"><%- micSvg %></button>
      </div>
      <div id="v-sug" class="sug" hidden>
        <% stock.forEach(function(s){ %>
          <button type="button" class="sug-item" onclick="elegirStock(this)"
                  data-id="<%= s.id %>" data-nombre="<%= s.nombre %>" data-precio="<%= s.precio %>"
                  data-q="<%= s.nombre.toLowerCase() %>">
            <span class="sug-nom"><%= s.nombre %></span>
            <span class="sug-meta">
              <b><%= fmt(s.precio) %></b>
              <span class="chip <%= s.cantidad <= 0 ? 'low' : '' %>">quedan <%= s.cantidad %></span>
            </span>
          </button>
        <% }); %>
        <div id="v-sug-vacio" class="sug-vacio" hidden>No hay nada así en tu stock. Podés cargarlo a mano más abajo.</div>
      </div>
    </div>
    <% } %>

    <div id="carrito" class="carrito" hidden>
      <div id="carrito-items"></div>
      <div class="carrito-total"><span>Total de la venta</span><b id="carrito-total">$0</b></div>
    </div>

    <button type="button" class="agregar" onclick="toggleManual()">+ Cargar algo que no está en el stock</button>
    <div id="bloque-manual" hidden>
      <label for="v-producto">Producto</label>
      <div class="field-mic">
        <input type="text" id="v-producto" autocomplete="off" placeholder="Ej: peinado, servicio...">
        <button type="button" class="mic" onclick="dictar('v-producto', this)"><%- micSvg %></button>
      </div>
      <label for="v-detalle">Detalle</label>
      <div class="field-mic">
        <input type="text" id="v-detalle" placeholder="Ej: fucsia, niña">
        <button type="button" class="mic" onclick="dictar('v-detalle', this)"><%- micSvg %></button>
      </div>
      <div class="row2">
        <div><label for="v-precio">Precio unitario</label><input type="number" id="v-precio" inputmode="numeric" placeholder="0"></div>
        <div><label for="v-cant">Cantidad</label><input type="number" id="v-cant" inputmode="numeric" value="1" min="1"></div>
      </div>
      <button type="button" class="agregar" onclick="agregarAlCarrito()">Agregar a la venta</button>
    </div>

    <div style="height:1px; background:var(--line); margin:16px 0;"></div>

    <div class="row2">
      <div>
        <label for="v-pago">Medio de pago</label>
        <select id="v-pago" name="pago">
          <% medios.forEach(function(m){ %><option><%= m.nombre %></option><% }); %>
        </select>
      </div>
      <div>
        <label for="v-cliente">Clienta (opcional)</label>
        <input type="text" id="v-cliente" name="cliente" placeholder="Nombre">
      </div>
    </div>

    <button class="primary" type="submit" id="v-guardar">Registrar venta</button>
    <div id="v-aviso" class="aviso-ok" hidden>Venta registrada</div>
  </form>
</div>
</div>

<div class="col-list">
<h2 class="sub">Últimas ventas</h2>
<div id="banner-pend" class="banner-pend" hidden></div>
<div id="ventas-vacio" class="empty" <%= ventas.length ? 'hidden' : '' %>>Todavía no hay ventas cargadas.</div>
<div class="list-grid" id="lista-ventas">
<% ventas.forEach(function(v){ %>
  <div class="item">
    <form class="inline-form" method="post" action="/ventas/borrar" data-confirm="¿Borrar esta venta?">
      <input type="hidden" name="clave" value="<%= v.clave %>">
      <button class="del" type="submit">&times;</button>
    </form>
    <div class="head">
      <span class="name"><%= v.items.length > 1 ? v.items.length + ' productos' : (v.items[0].producto || 'Venta') %></span>
      <span class="amount pos"><%= fmt(v.total) %></span>
    </div>
    <% if (v.items.length > 1 || v.items[0].cantidad > 1) { %>
      <div class="lineas">
        <% v.items.forEach(function(i){ %>
          <div class="linea">
            <span><%= i.cantidad > 1 ? i.cantidad + ' x ' : '' %><%= i.producto || 'Producto' %><%= i.detalle ? ' — ' + i.detalle : '' %></span>
            <span class="linea-monto"><%= fmt(i.precio) %></span>
          </div>
        <% }); %>
      </div>
    <% } else if (v.items[0].detalle) { %>
      <div class="muted" style="margin:2px 0 4px;"><%= v.items[0].detalle %></div>
    <% } %>
    <div class="meta">
      <span class="chip"><%= v.vendedor %></span>
      <span class="chip pay"><%= v.pago %></span>
      <% if (v.cliente) { %><span><%= v.cliente %></span><% } %>
      <span><%= fechaCorta(v.creado_en) %></span>
    </div>
  </div>
<% }); %>
</div>
</div>
</div>
<%- include('partials/nav') %>
<%- include('partials/foot') %>
