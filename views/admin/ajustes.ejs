<%- include('../partials/head') %>
<%- include('../partials/subnav-admin') %>
<% var tipoLabel = { texto:'Texto', numero:'Número', fecha:'Fecha' }; %>
<h1 class="title">Ajustes</h1>

<% if (ok == 1) { %><div class="alert ok">Campo agregado. Ya aparece en el formulario de Pedidos.</div><% } %>
<% if (ok == 2) { %><div class="alert ok">Medio de pago agregado.</div><% } %>
<% if (impError) { %><div class="alert"><%= impError %></div><% } %>
<% if (imp) { %>
  <div class="alert ok">
    Importación lista: <b><%= imp.nuevos %></b> productos nuevos, <b><%= imp.act %></b> actualizados<% if (imp.ign) { %>, <b><%= imp.ign %></b> filas ignoradas (sin nombre)<% } %>.
  </div>
<% } %>

<div class="card">
  <h2 class="sub">Medios de pago</h2>
  <p class="muted" style="margin:0 0 12px;">Los que aparecen al cargar una venta o un gasto. Agregá los que uses en tu negocio.</p>

  <h3 style="font-size:12.5px; color:var(--ink-soft); text-transform:uppercase; letter-spacing:.4px; margin:0 0 8px;">En ventas</h3>
  <div class="medios">
    <% mediosVenta.forEach(function(m){ %>
      <span class="medio">
        <%= m.nombre %>
        <form class="inline-form" method="post" action="/admin/ajustes/medios/<%= m.id %>/borrar" data-confirm="¿Borrar <%= m.nombre %>?">
          <button type="submit">&times;</button>
        </form>
      </span>
    <% }); %>
  </div>
  <form method="post" action="/admin/ajustes/medios" class="medio-form">
    <input type="hidden" name="para" value="venta">
    <input type="text" name="nombre" placeholder="Ej: Cuenta DNI, Naranja X..." required>
    <button class="ghost" type="submit">Agregar</button>
  </form>

  <div style="height:1px; background:var(--line); margin:16px 0;"></div>

  <h3 style="font-size:12.5px; color:var(--ink-soft); text-transform:uppercase; letter-spacing:.4px; margin:0 0 8px;">En gastos</h3>
  <div class="medios">
    <% mediosGasto.forEach(function(m){ %>
      <span class="medio">
        <%= m.nombre %>
        <form class="inline-form" method="post" action="/admin/ajustes/medios/<%= m.id %>/borrar" data-confirm="¿Borrar <%= m.nombre %>?">
          <button type="submit">&times;</button>
        </form>
      </span>
    <% }); %>
  </div>
  <form method="post" action="/admin/ajustes/medios" class="medio-form">
    <input type="hidden" name="para" value="gasto">
    <input type="text" name="nombre" placeholder="Ej: Cheque, Fiado..." required>
    <button class="ghost" type="submit">Agregar</button>
  </form>
</div>

<div class="card">
  <h2 class="sub">Cargar productos desde Excel</h2>
  <p class="muted" style="margin:0 0 10px;">Subí una planilla y se cargan todos tus productos de una vez, en vez de uno por uno.</p>
  <div class="hint" style="margin:0 0 12px;">
    <b>Columnas que toma:</b> <%= CAMPOS.join(' · ') %>.<br>
    Solo <b>Nombre</b> es obligatorio; el resto puede ir vacío. No importan las mayúsculas ni los acentos en los encabezados.<br>
    Si un producto ya existe (mismo nombre), <b>se le suma la cantidad</b> y se actualiza el precio.
  </div>
  <a class="ghost" href="/admin/ajustes/plantilla.xlsx" style="display:block; text-align:center; text-decoration:none; margin-bottom:12px;">Descargar plantilla de ejemplo</a>
  <form method="post" action="/admin/ajustes/importar" enctype="multipart/form-data">
    <label for="imp-file">Archivo (.xlsx o .csv)</label>
    <input type="file" id="imp-file" name="archivo" accept=".xlsx,.xls,.csv" required>
    <button class="primary" type="submit">Importar productos</button>
  </form>
</div>

<div class="card">
  <h2 class="sub">Campos del formulario de Pedidos</h2>
  <p class="muted" style="margin:0 0 12px;">Armá el formulario de pedidos a la medida de tu negocio. Los campos fijos (cliente, teléfono, fecha de entrega, estado, seña, total y notas) están siempre. Acá agregás los tuyos: por ejemplo <i>Tono, Largo</i> para extensiones, o <i>Sabor, Porciones</i> para pastelería.</p>
  <form method="post" action="/admin/ajustes/campos">
    <label for="c-nom">Nombre del campo</label>
    <input type="text" id="c-nom" name="nombre" placeholder="Ej: Color, Talle, Sabor..." required>
    <label for="c-tipo">Tipo</label>
    <select id="c-tipo" name="tipo">
      <% tipos.forEach(function(t){ %><option value="<%= t %>"><%= tipoLabel[t] %></option><% }); %>
    </select>
    <button class="primary" type="submit">Agregar campo</button>
  </form>
</div>

<h2 class="sub">Campos actuales</h2>
<% if (!campos.length) { %>
  <div class="empty">No hay campos personalizados. Agregá el primero arriba.</div>
<% } else { campos.forEach(function(c, i){ %>
  <div class="item">
    <form class="inline-form" method="post" action="/admin/ajustes/campos/<%= c.id %>/borrar" data-confirm="¿Borrar el campo &quot;<%= c.nombre %>&quot;? Los pedidos ya cargados conservan su información.">
      <button class="del" type="submit">&times;</button>
    </form>
    <div class="head">
      <span class="name"><%= c.nombre %></span>
      <span class="chip"><%= tipoLabel[c.tipo] || c.tipo %></span>
    </div>
    <div class="qty-btns" style="margin-top:9px;">
      <% if (i > 0) { %>
        <form class="inline-form" method="post" action="/admin/ajustes/campos/<%= c.id %>/mover" style="flex:1;">
          <input type="hidden" name="dir" value="arriba"><button type="submit" style="width:100%;">↑ Subir</button>
        </form>
      <% } %>
      <% if (i < campos.length - 1) { %>
        <form class="inline-form" method="post" action="/admin/ajustes/campos/<%= c.id %>/mover" style="flex:1;">
          <input type="hidden" name="dir" value="abajo"><button type="submit" style="width:100%;">↓ Bajar</button>
        </form>
      <% } %>
    </div>
  </div>
<% }); } %>
<%- include('../partials/nav') %>
<%- include('../partials/foot') %>
