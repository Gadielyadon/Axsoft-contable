<%- include('../partials/head') %>
<%- include('../partials/subnav-admin') %>
<%
  var qs = (rango.r === 'rango')
    ? '?r=rango&desde=' + encodeURIComponent(rango.desde) + '&hasta=' + encodeURIComponent(rango.hasta)
    : '?r=' + rango.r;
  var etiquetas = { hoy:'Hoy', semana:'Esta semana', mes:'Este mes', todo:'Todo', rango:'Período elegido' };
  var hs = function(n){ return (Math.round(n*100)/100).toString().replace('.', ',') + ' hs'; };
%>
<h1 class="title">Sueldos</h1>

<div class="card" style="padding:12px 14px;">
  <div class="subnav" style="margin-bottom:0;">
    <a href="/admin/sueldos?r=hoy"    class="<%= rango.r==='hoy'    ? 'active':'' %>">Hoy</a>
    <a href="/admin/sueldos?r=semana" class="<%= rango.r==='semana' ? 'active':'' %>">Esta semana</a>
    <a href="/admin/sueldos?r=mes"    class="<%= rango.r==='mes'    ? 'active':'' %>">Este mes</a>
    <a href="/admin/sueldos?r=todo"   class="<%= rango.r==='todo'   ? 'active':'' %>">Todo</a>
  </div>
  <form method="get" action="/admin/sueldos" style="margin-top:10px;">
    <input type="hidden" name="r" value="rango">
    <div class="row2">
      <div><label for="f-desde">Desde</label><input type="date" id="f-desde" name="desde" value="<%= rango.desde %>"></div>
      <div><label for="f-hasta">Hasta</label><input type="date" id="f-hasta" name="hasta" value="<%= rango.hasta %>"></div>
    </div>
    <button class="ghost" type="submit" style="width:100%; margin-top:10px;">Ver este período</button>
  </form>
</div>

<div class="stat-grid">
  <div class="stat"><div class="lbl">Horas del período</div><div class="val"><%= hs(totalHoras) %></div></div>
  <div class="stat"><div class="lbl">Sueldos a pagar</div><div class="val neg"><%= fmt(totalSueldos) %></div></div>
</div>
<p class="muted" style="margin:-6px 0 14px;">Mostrando: <b><%= etiquetas[rango.r] %></b><% if (rango.desde) { %> · <%= rango.desde %> a <%= rango.hasta %><% } %></p>

<div class="card">
  <h2 class="sub">Agregar integrante</h2>
  <form method="post" action="/admin/sueldos">
    <label for="eq-nom">Nombre</label>
    <input type="text" id="eq-nom" name="nombre" placeholder="Nombre" required>
    <label for="eq-rol">Rol</label>
    <input type="text" id="eq-rol" name="rol" placeholder="Ej: Venta / atención">
    <div class="row2">
      <div><label for="eq-tar">Precio por hora</label><input type="number" id="eq-tar" name="tarifa" inputmode="numeric" placeholder="0"></div>
      <div><label for="eq-com">Comisión (%)</label><input type="number" id="eq-com" name="comision" inputmode="numeric" value="0"></div>
    </div>
    <button class="primary" type="submit">Agregar</button>
  </form>
</div>

<h2 class="sub">Equipo — tocá a cada uno para cargarle horas</h2>
<% if (!filas.length) { %>
  <div class="empty">Todavía no cargaste al equipo. Agregá el primero arriba.</div>
<% } else { %><div class="list-grid"><% filas.forEach(function(e){ %>
  <a class="item persona" href="/admin/sueldos/<%= e.id %><%= qs %>">
    <div class="head">
      <span class="name"><%= e.nombre %></span>
      <span class="amount"><%= fmt(e.total) %></span>
    </div>
    <div class="meta">
      <% if (e.rol) { %><span class="chip"><%= e.rol %></span><% } %>
      <span class="chip"><%= hs(e.horasPeriodo) %></span>
      <span><%= fmt(e.tarifa) %> la hora</span>
      <% if (e.comision > 0) { %><span><%= e.comision %>% comisión</span><% } %>
    </div>
    <span class="ver-mas">Ver y cargar horas →</span>
  </a>
<% }); %></div><% } %>

<div class="card">
  <h2 class="sub">Resultado del período</h2>
  <div class="bar"><span>Ventas</span><span class="v pos"><%= fmt(ventasTotal) %></span></div>
  <div class="bar"><span>Gastos</span><span class="v neg"><%= fmt(gastosOp) %></span></div>
  <div class="bar"><span>Sueldos</span><span class="v neg"><%= fmt(totalSueldos) %></span></div>
  <div class="bar"><span>Neto</span><span class="v <%= neto>=0?'pos':'neg' %>"><%= fmt(neto) %></span></div>
</div>
<%- include('../partials/nav') %>
<%- include('../partials/foot') %>
