<%- include('../partials/head') %>
<%- include('../partials/subnav-admin') %>
<h1 class="title">Objetivo y proyección</h1>

<div class="card">
  <h2 class="sub">Objetivo del evento</h2>
  <p class="muted" style="margin:0 0 10px;">Cuánto querés vender en total. La proyección sale sola de tu stock real, no de suposiciones.</p>
  <form method="post" action="/admin/produccion/objetivo">
    <label for="pr-obj">Objetivo de venta ($)</label>
    <input type="number" id="pr-obj" name="objetivo" inputmode="numeric" value="<%= objetivo || '' %>" placeholder="0">
    <button class="primary" type="submit">Guardar objetivo</button>
  </form>
</div>

<div class="stat-grid">
  <div class="stat"><div class="lbl">Si vendés todo tu stock</div><div class="val pos"><%= fmt(ingreso) %></div></div>
  <div class="stat"><div class="lbl">Costo de esa mercadería</div><div class="val neg"><%= fmt(costo) %></div></div>
  <div class="stat wide"><div class="lbl">Margen bruto potencial</div><div class="val <%= margen>=0?'pos':'neg' %>"><%= fmt(margen) %></div></div>
  <div class="stat wide">
    <div class="lbl">Vs. objetivo</div>
    <div class="val <%= diffObjetivo===null ? '' : (diffObjetivo>=0?'pos':'neg') %>" style="font-size:14px;">
      <% if (diffObjetivo===null) { %>Cargá un objetivo arriba
      <% } else if (diffObjetivo>=0) { %>Tu stock cubre el objetivo, con margen de <%= fmt(diffObjetivo) %>
      <% } else { %>Con este stock faltarían <%= fmt(-diffObjetivo) %> para llegar<% } %>
    </div>
  </div>
</div>

<% if (objetivo > 0) { %>
<div class="card">
  <h2 class="sub">Cómo venís</h2>
  <div class="bar"><span>Objetivo</span><span class="v"><%= fmt(objetivo) %></span></div>
  <div class="bar"><span>Vendido hasta ahora</span><span class="v pos"><%= fmt(vendido) %></span></div>
  <div class="bar"><span>Te falta vender</span><span class="v <%= faltaVender > 0 ? 'neg' : 'pos' %>"><%= faltaVender > 0 ? fmt(faltaVender) : '¡Objetivo cumplido!' %></span></div>
</div>
<% } %>

<h2 class="sub">Lo que tenés para vender (<%= unidades %> unidades)</h2>
<% if (!items.length) { %>
  <div class="empty">No tenés stock cargado. Cargalo desde <b>Stock</b> y la proyección se arma sola.</div>
<% } else { %><div class="list-grid"><% items.forEach(function(p){ %>
  <div class="item">
    <div class="head">
      <span class="name"><%= p.nombre %></span>
      <span class="amount pos"><%= fmt(p.cantidad * p.precio) %></span>
    </div>
    <div class="meta">
      <% if (p.categoria) { %><span class="chip"><%= p.categoria %></span><% } %>
      <span><%= p.cantidad %> x <%= fmt(p.precio) %></span>
      <% if (p.costo) { %><span>costo <%= fmt(p.costo) %> c/u</span><% } %>
    </div>
  </div>
<% }); %></div><% } %>

<div class="hint" style="margin-top:12px;">
  Esta lista sale sola de tu <b>Stock</b>: no hace falta cargar los productos dos veces.
  Si querés cambiar cantidades o precios, hacelo desde la sección <b>Stock</b> y acá se actualiza solo.
</div>
<%- include('../partials/nav') %>
<%- include('../partials/foot') %>
