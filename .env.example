# Copiá este archivo como .env y completá los valores
NODE_ENV=production
PORT=3000

# Secreto para firmar las cookies de sesión. PONÉ UNO LARGO Y ALEATORIO.
# Podés generarlo con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambiame-por-una-cadena-larga-y-aleatoria

# Ruta del archivo de base (por defecto db/axsoft.db)
# DB_PATH=/var/www/axsoft-contable/db/axsoft.db

# Credenciales del superadmin de plataforma (solo se usan la 1ra vez, al correr init-db)
SUPERADMIN_NAME=AxSoft
SUPERADMIN_USER=admin
SUPERADMIN_PASS=cambiame123
