# /etc/nginx/sites-available/axsoft-contable
# Reemplazá tudominio.com por tu dominio real.
# 1) Primero dejá solo el bloque :80, corré certbot, y él agrega el SSL solo.

server {
    listen 80;
    server_name tudominio.com www.tudominio.com;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Archivos estáticos servidos directo por Nginx (más rápido)
    location /css/   { proxy_pass http://127.0.0.1:3000; }
    location /js/    { proxy_pass http://127.0.0.1:3000; }
    location /img/   { proxy_pass http://127.0.0.1:3000; }

    client_max_body_size 5M;
}

# Después de correr:  sudo certbot --nginx -d tudominio.com -d www.tudominio.com
# Certbot agrega automáticamente el bloque listen 443 con el certificado de Let's Encrypt.
